PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/rabtpoint?retryWrites=true&w=majority
# Optional: use if mongodb+srv DNS fails locally (Atlas → Connect → Drivers → standard connection string)
MONGO_URI_STANDARD=
JWT_SECRET=change-this-to-a-long-random-string
LOCAL_URL=http://localhost:5173
WEBSITE_URL=https://rabtpoint.com

# Email (production). Leave empty for local dev — OTP prints in server terminal + API response.
RESEND_API_KEY=
OTP_FROM_EMAIL=RabtPoint <onboarding@resend.dev>
DEV_OTP_CONSOLE=true

ADMIN_EMAILS=you@example.com

# Optional uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
